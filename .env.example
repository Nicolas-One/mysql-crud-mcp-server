# MySQL 数据库配置
# 复制此文件为 .env 并填入您的实际配置信息
# 支持多种配置名称，选择其中一种即可

# 主机地址（支持：MYSQL_HOST / DB_HOST / DATABASE_HOST / HOST）
DB_HOST=127.0.0.1

# 端口号（支持：MYSQL_PORT / DB_PORT / DATABASE_PORT / PORT）
DB_PORT=3306

# 用户名（支持：MYSQL_USER / DB_USER / DATABASE_USER / USER / MYSQL_USERNAME / DB_USERNAME）
DB_USER=root

# 密码（支持：MYSQL_PASSWORD / DB_PASSWORD / DATABASE_PASSWORD / PASSWORD）
DB_PASSWORD=your_password

# 数据库名（支持：MYSQL_DATABASE / DB_NAME / DATABASE_NAME / DATABASE / DB_DATABASE）
DB_NAME=your_database

# 其他配置名称示例（选择其中一种即可）：
# MYSQL_HOST=127.0.0.1
# DATABASE_HOST=127.0.0.1
# HOST=127.0.0.1
#
# MYSQL_PORT=3306
# DATABASE_PORT=3306
# PORT=3306
#
# MYSQL_USER=root
# DATABASE_USER=root
# USER=root
#
# MYSQL_PASSWORD=your_password
# DATABASE_PASSWORD=your_password
# PASSWORD=your_password
#
# MYSQL_DATABASE=your_database
# DATABASE_NAME=your_database
# DATABASE=your_database

