# MySQL 数据库配置
# 复制此文件为 .env 并填入您的实际配置信息
# 支持两种格式：标准 KEY=VALUE 格式 或 INI 格式

# ============================================
# 格式一：标准 KEY=VALUE 格式（推荐）
# ============================================

# 主机地址（支持：MYSQL_HOST / DB_HOST / DATABASE_HOST / HOST / HOSTNAME）
DB_HOST=127.0.0.1

# 端口号（支持：MYSQL_PORT / DB_PORT / DATABASE_PORT / PORT / HOSTPORT）
DB_PORT=3306

# 用户名（支持：MYSQL_USER / DB_USER / DATABASE_USER / USER / MYSQL_USERNAME / DB_USERNAME / USERNAME）
DB_USER=root

# 密码（支持：MYSQL_PASSWORD / DB_PASSWORD / DATABASE_PASSWORD / PASSWORD）
DB_PASSWORD=your_password

# 数据库名（支持：MYSQL_DATABASE / DB_NAME / DATABASE_NAME / DATABASE / DB_DATABASE）
DB_NAME=your_database

# 字符集（支持：CHARSET / CHARACTER_SET，默认：utf8）
CHARSET=utf8


# ============================================
# 格式二：INI 格式（[DATABASE] section）
# ============================================
# 取消下面的注释并注释掉上面的配置即可使用 INI 格式

# [DATABASE]
# TYPE=mysql
# HOSTNAME=127.0.0.1
# HOSTPORT=3306
# USERNAME=root
# PASSWORD=your_password
# DATABASE=your_database
# CHARSET=utf8
# DEBUG=true
